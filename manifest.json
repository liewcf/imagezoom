{
  "manifest_version": 3,
  "name": "Image Zoom",
  "version": "0.1.3",
  "description": "Zoom images in a full-page overlay after double-clicking them.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
